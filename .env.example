# Configurações do Banco de Dados PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=insira_uma_senha_forte_aqui
POSTGRES_DB=acheaq

# URL de conexão do Prisma (Usado localmente se necessário)
# Se estiver rodando fora do docker: postgresql://postgres:senha@localhost:5432/acheaq?schema=public
# Se estiver dentro do docker: postgresql://postgres:senha@db:5432/acheaq?schema=public
DATABASE_URL=postgresql://postgres:insira_uma_senha_forte_aqui@localhost:5432/acheaq?schema=public

# Configurações do Servidor Backend
BACKEND_PORT=5000
NODE_ENV=development
JWT_SECRET=gerar_uma_hash_segura_de_32_bytes_ou_mais

# Configurações do Frontend
FRONTEND_URL=http://localhost:3000

# Configurações do pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@acheaq.local
PGADMIN_DEFAULT_PASSWORD=insira_uma_senha_admin_forte_aqui
PGADMIN_PORT_BINDING=5080:80

