datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  name        String
  phone       String
  registration String
  course      String
  institution String
  role        UserRole  @default(USER)
  items       Item[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]
}

model Item {
  id             String   @id @default(uuid())
  title          String
  description    String
  photoUrl       String? // URL da foto enviada
  category       Category @relation(fields: [categoryId], references: [id])
  categoryId     String
  location       String // Local (ex: Bloco A, Estacionamento)
  occurrenceDate DateTime // Data da ocorrência
  type           String @default("LOST") // Perdido ou Encontrado
  status         String @default("OPEN") // Aberto ou Resolvido
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}