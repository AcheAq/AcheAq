# Variáveis de ambiente do frontend (Vite)
# Apenas variáveis com o prefixo VITE_ são expostas ao código do cliente.

# URL base da API usada pelo Axios (src/services/api.js).
# Padrão "/api": em dev o proxy do Vite reescreve /api -> backend;
# em produção o nginx encaminha /api/ -> backend. Deixe assim salvo
# necessidade de apontar para um backend externo (ex.: https://api.exemplo.com).
VITE_API_URL=/api
